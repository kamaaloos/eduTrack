{
  "expo": {
    "name": "eduTrack",
    "slug": "eduTrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "edutrack",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maylesoft.edutrack"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#E8F2FA"
      },
      "package": "com.maylesoft.edutrack",
      "versionCode": 2,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#6B9FD4",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "cover",
            "backgroundColor": "#6B9FD4"
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "cover",
            "backgroundColor": "#6B9FD4",
            "enableFullScreenImage_legacy": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow eduTrack to access your photos to set your profile picture."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9d115957-ea1b-41e7-90be-30b91ef386ac"
      }
    },
    "owner": "kamaaloos"
  }
}
