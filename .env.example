# Copy to .env and fill in your Firebase values

# Registry project: hosts the public school list (schoolRegistry collection).
# If omitted, EXPO_PUBLIC_FIREBASE_* is used as the registry.
EXPO_PUBLIC_REGISTRY_API_KEY=
EXPO_PUBLIC_REGISTRY_AUTH_DOMAIN=
EXPO_PUBLIC_REGISTRY_PROJECT_ID=
EXPO_PUBLIC_REGISTRY_STORAGE_BUCKET=
EXPO_PUBLIC_REGISTRY_MESSAGING_SENDER_ID=
EXPO_PUBLIC_REGISTRY_APP_ID=

# Default / fallback school Firebase project (also used when schoolRegistry is empty)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Dev: faster Metro resolution (Expo)
EXPO_USE_FAST_RESOLVER=1

# Windows: Metro often misses file saves without polling — enables live reload
CHOKIDAR_USEPOLLING=true

# Optional: show platform admin sign-in link on school picker (default: hidden; tap logo 5×)
# EXPO_PUBLIC_SHOW_PLATFORM_ADMIN_LINK=true
